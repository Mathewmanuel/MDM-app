<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0A1628"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp">

            <!-- Top Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Logo Block -->
                <LinearLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="#0D1E35"
                    android:gravity="center"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="#0066FF"/>
                </LinearLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DEVPULSE"
                    android:textSize="11sp"
                    android:textColor="#0066FF"
                    android:textStyle="bold"
                    android:letterSpacing="0.4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0"
                    android:textSize="10sp"
                    android:textColor="#E2E8F0"
                    android:background="#0D1E35"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device&#10;Management."
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enroll, monitor and manage devices securely."
                android:textSize="13sp"
                android:textColor="#E2E8F0"/>

        </LinearLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Status Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#0D1E35"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ENROLLMENT STATUS"
                        android:textSize="9sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.3"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Not Enrolled"
                        android:textSize="14sp"
                        android:textColor="#E2E8F0"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#FF3D57"/>

            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Device Owner -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#0D1E35"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DEVICE OWNER"
                        android:textSize="9sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.3"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/deviceOwnerText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NO"
                        android:textSize="22sp"
                        android:textColor="#FF3D57"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Last Synced -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#0D1E35"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LAST SYNCED"
                        android:textSize="9sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.3"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/lastSyncedText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Never"
                        android:textSize="14sp"
                        android:textColor="#E2E8F0"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- App Count Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#0D1E35"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="INSTALLED APPS"
                        android:textSize="9sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.3"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/appCountText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Calculating..."
                        android:textSize="14sp"
                        android:textColor="#E2E8F0"
                        android:textStyle="bold"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APPS"
                    android:textSize="9sp"
                    android:textColor="#0066FF"
                    android:textStyle="bold"
                    android:background="#0A1628"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:letterSpacing="0.2"/>

            </LinearLayout>

            <!-- Divider Label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#0066FF"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ENROLL THIS DEVICE"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:textStyle="bold"
                    android:letterSpacing="0.3"/>

            </LinearLayout>

            <!-- Token Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D1E35"
                android:padding="16dp"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ENROLLMENT TOKEN"
                    android:textSize="9sp"
                    android:textColor="#AAAAAA"
                    android:letterSpacing="0.3"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/tokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Paste token here"
                    android:textColor="#E2E8F0"
                    android:textSize="13sp"
                    android:background="#0A1628"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="text"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <!-- Enroll Button -->
            <Button
                android:id="@+id/enrollButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="ENROLL DEVICE"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:backgroundTint="#0066FF"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"/>

            <!-- Sync Now Button -->
            <Button
                android:id="@+id/syncNowButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="↻  SYNC NOW"
                android:textSize="12sp"
                android:textColor="#0066FF"
                android:letterSpacing="0.2"
                android:textStyle="bold"
                android:backgroundTint="#0D1E35"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp"/>

            <!-- Device Info Card -->
            <LinearLayout
                android:id="@+id/deviceInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D1E35"
                android:padding="20dp"
                android:visibility="gone"
                android:elevation="2dp">

                <!-- Card Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="14dp"
                        android:background="#0066FF"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DEVICE INFO"
                        android:textSize="10sp"
                        android:textColor="#0066FF"
                        android:letterSpacing="0.3"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#071810"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="#00CC66"
                            android:layout_marginEnd="5dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVE"
                            android:textSize="9sp"
                            android:textColor="#00CC66"
                            android:textStyle="bold"
                            android:letterSpacing="0.2"/>

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/deviceInfoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#E2E8F0"
                    android:lineSpacingExtra="10dp"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <!-- Bottom padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>